DB_PASSWORD=ChangeMeStrongPassword123!

JWT_SECRET_KEY=replace-with-at-least-32-characters-secret

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMeAdminPassword123!

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Host/IP that API clients can reach for MinIO media URLs.
# Real phone on same Wi-Fi: use the LAN IP of the machine running Docker/API, for example 192.168.1.139.
# Android emulator only: use 10.0.2.2.
# Browser on the same machine only: localhost can work, but do not use it for real phones.
HOST_IP=192.168.1.139

# Leave empty to disable FCM in local development.
FIREBASE_CREDENTIAL_JSON=
